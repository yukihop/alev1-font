{
  "name": "alevish-font",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "24.6"
  },
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "release:package": "node scripts/package-font-release.ts",
    "pages:build-all": "pnpm --filter font build && pnpm --filter docs build",
    "build": "pnpm --filter font build",
    "check": "pnpm --filter font check",
    "docs:build": "pnpm --filter docs build",
    "docs:dev": "pnpm --filter docs dev"
  }
}
